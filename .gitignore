# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/

# Build output
dist/
build/
.next/
out/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.override.yml may contain local port overrides — keep it local)
docker-compose.override.yml

# ── Cloudflared ───────────────────────────────────────────────────────────────
# Tunnel credentials contain secrets — never commit these
cloudflared/*.json
cloudflared/cert.pem

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
pm2-*.log

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
tmp/
temp/
